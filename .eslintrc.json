{
  "env": {
    "commonjs": true,
    "es2022": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "globals": {
    "fetch": "readonly",
    "FormData": "readonly",
    "Headers": "readonly",
    "Request": "readonly",
    "Response": "readonly"
  },
  "parser": "@babel/eslint-parser",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "root": true,
  "rules": {
    "comma-dangle": ["error", "always-multiline"]
  },
  "ignorePatterns": ["/example"]
}
